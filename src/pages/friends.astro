---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@layouts/MainGridLayout.astro";

const friends = [
	{
		name: "Joye Personal Blog",
		description: "Stay hungry, stay foolish",
		url: "https://joyehuang.me/",
		avatar: "https://joyehuang.me/favicon/favicon.ico",
	},
];
---

<MainGridLayout title="友链" description="友情链接">
	<div class="min-h-screen">
		<section class="card-base px-9 py-11 mb-8 onload-animation">
			<h1 class="text-4xl font-bold mb-3 text-black/90 dark:text-white/90">友链</h1>
			<p class="text-neutral-500 dark:text-neutral-400">一些值得拜访的朋友和站点。</p>
		</section>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
			{friends.map((friend) => (
				<a
					href={friend.url}
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`访问 ${friend.name}`}
					class="card-base group flex items-center gap-5 px-6 py-5 transition-all hover:-translate-y-1 hover:shadow-lg"
				>
					<img
						src={friend.avatar}
						alt={`${friend.name} avatar`}
						loading="lazy"
						class="h-16 w-16 shrink-0 rounded-full bg-neutral-100 object-cover ring-1 ring-black/10 dark:bg-neutral-800 dark:ring-white/10"
					/>
					<div class="min-w-0 flex-1">
						<div class="flex items-center gap-2">
							<h2 class="truncate text-xl font-bold text-black/90 dark:text-white/90">
								{friend.name}
							</h2>
							<Icon
								name="fa6-solid:arrow-up-right-from-square"
								class="shrink-0 text-sm text-neutral-400 transition group-hover:text-[var(--primary)]"
							/>
						</div>
						<p class="mt-1 line-clamp-2 text-sm text-neutral-500 dark:text-neutral-400">
							{friend.description}
						</p>
					</div>
				</a>
			))}
		</div>
	</div>
</MainGridLayout>
